<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- fill -->
    <solid android:color="#66FFFFFF"/> <!-- white at 40% alpha; change color/alpha as needed -->
    <!-- thin border -->
    <stroke android:width="1dp" android:color="#B3FFFFFF"/> <!-- slightly more opaque white -->
    <!-- rounded corners (pill) -->
    <corners android:radius="12dp"/>
    <!-- optional inset so stroke looks inner -->
    <padding android:left="8dp" android:top="4dp" android:right="8dp" android:bottom="4dp"/>
</shape>
