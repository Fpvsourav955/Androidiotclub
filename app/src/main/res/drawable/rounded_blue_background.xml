<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Border Layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#5AA0BD" /> <!-- Border color -->
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Inner Background Layer (Card Content) with Padding to Show Border -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#E0F0FF" /> <!-- Inner background -->
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
