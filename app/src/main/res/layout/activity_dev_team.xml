<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/babypowder"
    tools:context=".DevTeam">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            tools:ignore="ExtraText">
            <RelativeLayout
                android:layout_width="match_parent"
                android:background="#247B7B"
                android:layout_height="?actionBarSize">
                <ImageView
                    android:id="@+id/devback"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/back"
                    android:layout_marginTop="8dp"
                    android:padding="20dp"
                    app:srcCompat="@drawable/back"
                    app:tint="@android:color/white" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:text="@string/developers"
                    android:layout_margin="15dp"
                    android:gravity="center"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/dmsans_light"/>


            </RelativeLayout>


            <RelativeLayout
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="230dp">

                <RelativeLayout
                    android:id="@+id/relativeLayout"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_margin="20dp"
                    android:background="@drawable/developer_background">



                    <TextView
                        android:id="@+id/textView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_centerInParent="true"
                        android:layout_marginBottom="58dp"
                        android:layout_marginTop="20dp"
                        android:fontFamily="@font/robot1"
                        android:padding="20dp"
                        android:text="@string/sourav_kumar_pati"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textColorHint="@color/white"
                        android:textStyle="bold"
                        tools:ignore="RelativeOverlap" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignTop="@+id/textView"
                        android:layout_marginTop="20dp"
                        android:layout_alignParentBottom="true"
                        android:layout_centerInParent="true"
                        android:padding="20dp"
                        android:text="@string/android_lead"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        tools:ignore="RelativeOverlap" />

                    <ImageView
                        android:id="@+id/souravgit"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_marginEnd="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:importantForAccessibility="no"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:src="@drawable/icons8github144"
                        tools:ignore="RtlSymmetry" />

                    <ImageView
                        android:id="@+id/souravlink"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_alignParentBottom="true"
                        android:layout_centerInParent="true"
                        android:contentDescription="link"
                        android:paddingBottom="16dp"
                        android:src="@drawable/icons8linkedin144"
                        tools:ignore="HardcodedText,ImageContrastCheck" />

                    <ImageView
                        android:id="@+id/souravinsta"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_alignParentBottom="true"
                        android:layout_marginStart="30dp"
                        android:layout_marginEnd="100dp"
                        android:importantForAccessibility="no"
                        android:paddingBottom="16dp"
                        android:src="@drawable/icons8instagram144"
                        tools:ignore="ImageContrastCheck" />



                </RelativeLayout>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/souravimage"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_alignStart="@+id/relativeLayout"
                    android:layout_alignEnd="@+id/relativeLayout"
                    android:src="@drawable/sor"

                    app:civ_border_color="#247B7B"
                    app:civ_border_width="2dp"
                    tools:ignore="ImageContrastCheck" />
            </RelativeLayout>
            <RelativeLayout
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="230dp">

                <RelativeLayout
                    android:id="@+id/relativeLayout4"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_margin="20dp"
                    android:background="@drawable/developer_background">

                    <TextView
                        android:id="@+id/textView2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_centerInParent="true"
                        android:layout_marginBottom="58dp"
                        android:layout_marginTop="20dp"
                        android:fontFamily="@font/robot1"
                        android:padding="20dp"
                        android:text="@string/anshuman_mahanta"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textColorHint="@color/white"
                        android:textStyle="bold"
                        tools:ignore="RelativeOverlap" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignTop="@+id/textView2"
                        android:layout_marginTop="20dp"
                        android:layout_alignParentBottom="true"
                        android:layout_centerInParent="true"
                        android:padding="20dp"
                        android:text="@string/ui_ux_lead"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        tools:ignore="RelativeOverlap" />

                    <ImageView
                        android:id="@+id/anshmangit"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_marginEnd="30dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:importantForAccessibility="no"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:src="@drawable/icons8github144"
                        tools:ignore="RtlSymmetry" />

                    <ImageView
                        android:id="@+id/anshumanlink"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_alignParentBottom="true"
                        android:layout_centerInParent="true"
                        android:contentDescription="@string/link"
                        android:paddingBottom="16dp"
                        android:src="@drawable/icons8linkedin144"
                        tools:ignore="ImageContrastCheck" />

                    <ImageView
                        android:id="@+id/anshmaninsta"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_alignParentBottom="true"
                        android:layout_marginStart="30dp"
                        android:layout_marginEnd="100dp"
                        android:importantForAccessibility="no"
                        android:paddingBottom="16dp"
                        android:src="@drawable/icons8instagram144"
                        tools:ignore="ImageContrastCheck" />

                </RelativeLayout>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/anshumanimage"
                    android:src="@drawable/anshuman"

                    android:layout_width="match_parent"
                    android:layout_height="100dp"


                    android:layout_alignStart="@+id/relativeLayout4"
                    android:layout_alignEnd="@+id/relativeLayout4"

                    app:civ_border_color="#247B7B"
                    app:civ_border_width="2dp"
                    tools:ignore="ImageContrastCheck" />
            </RelativeLayout>
