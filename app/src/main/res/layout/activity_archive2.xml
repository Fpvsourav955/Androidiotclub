<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".Archive2">
    <androidx.core.widget.NestedScrollView
        android:id="@+id/event_archive_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:background="#F5F5F5"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">


            <TextView
                android:fontFamily="@font/dmsans_regular"
                android:id="@+id/archive_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Orientation 2024 Batch:"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:paddingBottom="8dp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:orientation="vertical">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/videoViewPager"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:overScrollMode="never"/>
            </LinearLayout>


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="24dp"
                android:elevation="6dp"
                android:background="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:fontFamily="@font/dmsans_medium"
                        android:id="@+id/event_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Orientation Program"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />


                    <TextView
                        android:id="@+id/event_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sep 31, 2024"
                        android:textSize="14sp"
                        android:textColor="#757575"
                        android:paddingTop="4dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewArchive"
                        android:layout_width="match_parent"
                        android:layout_height="500dp"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"

                        android:overScrollMode="never"
                        android:scrollbars="none"
                        android:orientation="horizontal" />


                    <TextView
                        android:fontFamily="@font/dmsans_semibold"
                        android:id="@+id/event_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"

                        android:textSize="16sp"
                        android:textColor="#424242"
                        android:lineSpacingExtra="4dp"
                        android:paddingTop="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>



        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.drawerlayout.widget.DrawerLayout>