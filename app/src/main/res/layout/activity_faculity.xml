<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/babypowder"
    android:fitsSystemWindows="true"
    tools:context=".Faculity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?actionBarSize"
            android:background="#247B7B"
            android:gravity="center">

            <ImageView
                android:id="@+id/devback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="20dp"
                android:contentDescription="@string/back"
                app:srcCompat="@drawable/back"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="15dp"
                android:gravity="center"
                android:text="@string/meet_our_faculty"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:fontFamily="@font/dmsans_light" />
        </RelativeLayout>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="6dp"
            android:text="@string/guiding_the_us_with_experience_and_knowledge"
            android:textColor="@color/black"
            android:textSize="12sp" />

        <com.facebook.shimmer.ShimmerFrameLayout
            android:visibility="visible"
            android:id="@+id/shimmer2"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/shimmer_bg"
            app:shimmer_auto_start="true"
            app:shimmer_duration="1500"
            />
        <com.facebook.shimmer.ShimmerFrameLayout
            android:visibility="visible"
            android:id="@+id/shimmer1"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/shimmer_bg"
            app:shimmer_auto_start="true"
            app:shimmer_duration="1500"
            />

        <com.facebook.shimmer.ShimmerFrameLayout
        android:visibility="visible"
        android:id="@+id/shimmer3"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/shimmer_bg"
        app:shimmer_auto_start="true"
        app:shimmer_duration="1500"
        />

            <androidx.cardview.widget.CardView
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:id="@+id/cardView1"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:elevation="6dp"
                app:cardCornerRadius="20dp"
                app:cardUseCompatPadding="true">

                <androidx.constraintlayout.widget.ConstraintLayout

                    android:id="@+id/facultyview1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/faculty_background">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/circleImageView"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_marginTop="12dp"
                        app:civ_border_color="@color/babypowder"
                        app:civ_border_overlay="true"
                        app:civ_border_width="2dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/facultyname1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/dmsans_regular"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/circleImageView"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/facultytitle1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        app:layout_constraintTop_toBottomOf="@id/facultyname1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:id="@+id/cardView2"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:elevation="6dp"
                app:cardCornerRadius="20dp"
                app:cardUseCompatPadding="true">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/facultyview2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/faculty_background">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/circleImageView1"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_marginTop="12dp"
                        app:civ_border_color="@color/babypowder"
                        app:civ_border_overlay="true"
                        app:civ_border_width="2dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/facultyname2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/dmsans_regular"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toBottomOf="@id/circleImageView1"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/facultytitle2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/dmsans_light"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        app:layout_constraintTop_toBottomOf="@id/facultyname2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:id="@+id/cardView3"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:elevation="6dp"
            app:cardCornerRadius="20dp"
            app:cardUseCompatPadding="true">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/facultyview3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/faculty_background">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/circleImageView2"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_marginTop="12dp"
                    android:src="@drawable/registrar"
                    app:civ_border_color="@color/babypowder"
                    app:civ_border_overlay="true"
                    app:civ_border_width="2dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/facultyname3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/dmsans_regular"

                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/circleImageView2" />

                <TextView
                    android:id="@+id/facultytitle3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/dmsans_light"

                    android:textColor="@color/white"
                    android:textSize="14sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/facultyname3" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>


    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
