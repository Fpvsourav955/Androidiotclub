<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/frame_container"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginTop="60dp"
    tools:context=".ProfileFragment"
    android:background="@color/babypowder"
    >

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="240dp"
      android:background="@drawable/profile_background"
      android:orientation="vertical">

    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/Profile_image"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="32dp"
        android:src="@drawable/person"
        app:civ_border_color="@color/babypowder"
        android:layout_gravity="center"
        app:civ_border_width="2dp"/>
    <TextView
        android:id="@+id/Profile_name"
        android:layout_width="match_parent"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:textColor="@color/white"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:text="@string/user"
        android:fontFamily="@font/robot1"
        android:textSize="24sp"/>

    <TextView
        android:id="@+id/Profile_email"
        android:layout_width="match_parent"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:fontFamily="@font/dmsans_regular"
        android:layout_height="wrap_content"
        android:text="@string/email" />
  </LinearLayout>
  <androidx.cardview.widget.CardView
      android:layout_marginTop="200dp"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginStart="16dp"
      android:layout_marginEnd="16dp"
      app:cardElevation="8dp"
      app:cardCornerRadius="30dp"
      app:cardMaxElevation="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@drawable/white_cornor_background">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:orientation="horizontal"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/logout"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="8dp"
            android:layout_weight="1"
            android:background="@drawable/edittext_green"
            android:gravity="center"
            android:text="@string/logout"
            android:textColor="@color/babypowder"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/Changepass"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_margin="8dp"
            android:layout_weight="1"
            android:background="@drawable/edittext_green"
            android:gravity="center"
            android:text="@string/change_password"
            android:textColor="@color/babypowder"
            android:textStyle="bold" />

      </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>


  </androidx.cardview.widget.CardView>

  <ScrollView
      android:layout_marginTop="300dp"
      android:layout_width="match_parent"
      android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
      android:orientation="vertical">
      <androidx.constraintlayout.widget.ConstraintLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:padding="16dp"
          android:layout_margin="16dp"
          android:background="@drawable/rounded_card_bg"
          android:elevation="4dp">

     
        <ImageView
            android:id="@+id/iconProfile"
            android:layout_width="24dp"
            android:alpha="0.8"
            android:layout_height="24dp"
            android:importantForAccessibility="no"
            android:src="@drawable/profile"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    
        <TextView
            android:id="@+id/titleProfileCompletion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.8"
            android:text="@string/profile_completion"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="16sp"
            app:layout_constraintStart_toEndOf="@id/iconProfile"
            app:layout_constraintTop_toTopOf="@id/iconProfile"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/completionPercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textColor="@color/Tiffantblue"
            android:textStyle="bold"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/titleProfileCompletion"
            tools:ignore="HardcodedText" />

        <ProgressBar
            android:id="@+id/profileProgressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:progress="50"
            android:max="100"
            android:progressDrawable="@drawable/progress_bar_orange"
            app:layout_constraintTop_toBottomOf="@id/titleProfileCompletion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/profileCompletionNote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/complete_your_profile_to_unlock_all_features"
            android:textColor="#888888"
            android:textSize="13sp"
            app:layout_constraintTop_toBottomOf="@id/profileProgressBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp" />

      </androidx.constraintlayout.widget.ConstraintLayout>

      <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginStart="16dp"
          android:layout_marginEnd="16dp"
          android:layout_marginBottom="16dp"
          android:elevation="4dp"
          app:cardCornerRadius="16dp"
          app:cardMaxElevation="6dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

          <ImageView
              android:id="@+id/imageView4"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:alpha="0.8"
              android:importantForAccessibility="no"
              android:src="@drawable/mortarboard"
              android:backgroundTint="@color/tertiaryColor"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toTopOf="parent" />

      
          <TextView
              android:id="@+id/textView12"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="8dp"
              android:text="@string/academic_information"
              android:textSize="16sp"
              android:textStyle="bold"
              android:fontFamily="@font/dmsans_regular"
              app:layout_constraintStart_toEndOf="@id/imageView4"
              app:layout_constraintTop_toTopOf="@id/imageView4" />

      
          <ImageView
              android:id="@+id/imageView6"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginTop="16dp"
              android:alpha="0.8"
              android:importantForAccessibility="no"
              android:src="@drawable/outline_calendar_today_24"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toBottomOf="@id/imageView4" />

     
          <TextView
              android:id="@+id/textView28"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="8dp"
              android:layout_marginBottom="6dp"
              android:fontFamily="@font/dmsans_regular"
              android:text="@string/year_semester"
              android:textColor="@color/black"
              android:textSize="14sp"
              app:layout_constraintBottom_toBottomOf="@id/imageView6"
              app:layout_constraintStart_toEndOf="@id/imageView6" />

        
          <TextView
              android:id="@+id/year"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/not_specified"
              android:textSize="11sp"
              android:textStyle="italic"
              android:fontFamily="@font/dmsans_regular"
              app:layout_constraintTop_toBottomOf="@id/textView28"
              app:layout_constraintStart_toStartOf="@id/textView28" />

        
          <ImageView
              android:id="@+id/yearedit"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginTop="8dp"
              android:alpha="0.5"
              android:importantForAccessibility="no"
              android:src="@drawable/ic_edit"
              app:layout_constraintTop_toTopOf="@id/textView28"
              app:layout_constraintEnd_toEndOf="parent" />

          <ImageView
              android:id="@+id/imageView8"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginTop="16dp"
              android:alpha="0.8"
              android:importantForAccessibility="no"
              android:src="@drawable/department"
              app:layout_constraintTop_toBottomOf="@id/year"
              app:layout_constraintStart_toStartOf="parent" />

         
          <TextView
              android:id="@+id/textView29"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="8dp"
              android:layout_marginBottom="6dp"
              android:fontFamily="@font/dmsans_regular"
              android:text="@string/branch_department"
              android:textColor="@color/black"
              android:textSize="14sp"
              app:layout_constraintBottom_toBottomOf="@id/imageView8"
              app:layout_constraintStart_toEndOf="@id/imageView8" />

  
          <TextView
              android:id="@+id/branch"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/not_specified"
              android:textSize="11sp"
              android:textStyle="italic"
              android:fontFamily="@font/dmsans_regular"
              app:layout_constraintTop_toBottomOf="@id/textView29"
              app:layout_constraintStart_toStartOf="@id/textView29" />

          <ImageView
              android:id="@+id/branchedit"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginTop="8dp"
              android:alpha="0.5"
              android:importantForAccessibility="no"
              android:src="@drawable/ic_edit"
              app:layout_constraintTop_toTopOf="@id/textView29"
              app:layout_constraintEnd_toEndOf="parent" />
          
          <ImageView
              android:id="@+id/imageView9"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginTop="16dp"
              android:alpha="0.8"
              android:importantForAccessibility="no"
              android:src="@drawable/identification"
              app:layout_constraintTop_toBottomOf="@id/branch"
              app:layout_constraintStart_toStartOf="parent" />
          <TextView
              android:id="@+id/textView30"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="8dp"
              android:layout_marginBottom="6dp"
              android:fontFamily="@font/dmsans_regular"
              android:text="@string/roll_number"
              android:textColor="@color/black"
              android:textSize="14sp"
              app:layout_constraintBottom_toBottomOf="@id/imageView9"
              app:layout_constraintStart_toEndOf="@id/imageView9" />

      
          <TextView
              android:id="@+id/rollno"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/not_specified"
              android:textSize="11sp"
              android:textStyle="italic"
              android:fontFamily="@font/dmsans_regular"
              app:layout_constraintTop_toBottomOf="@id/textView30"
              app:layout_constraintStart_toStartOf="@id/textView30" />

    
          <ImageView
              android:id="@+id/rolledit"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginTop="8dp"
              android:alpha="0.5"
              android:importantForAccessibility="no"
              android:src="@drawable/ic_edit"
              app:layout_constraintTop_toTopOf="@id/textView30"
              app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
      </androidx.cardview.widget.CardView>


      <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginStart="16dp"
          android:layout_marginEnd="16dp"
          android:layout_marginBottom="16dp"
          android:layout_marginTop="0dp"
          app:cardCornerRadius="16dp"
          android:elevation="4dp"
          app:cardMaxElevation="6dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="148dp"
            >

          <ImageView
              android:id="@+id/imageView10"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginStart="16dp"
              android:layout_marginTop="16dp"
              android:alpha="0.8"
              android:importantForAccessibility="no"
              android:src="@drawable/outline_add_link_24"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toTopOf="parent" />

          <TextView
              android:id="@+id/textView34"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="6dp"
              android:layout_marginTop="2dp"
              android:fontFamily="@font/dmsans_regular"
              android:text="@string/social_links"
              android:textSize="16sp"
              android:textStyle="bold"
              app:layout_constraintStart_toEndOf="@id/imageView10"
              app:layout_constraintTop_toTopOf="@id/imageView10" />

      
          <ImageView
              android:id="@+id/imageView13"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginStart="16dp"
              android:layout_marginTop="16dp"
              android:alpha="0.8"
              android:importantForAccessibility="no"
              android:src="@drawable/linkedin"
              app:layout_constraintStart_toStartOf="parent"
              app:layout_constraintTop_toBottomOf="@+id/imageView10" />

          <TextView
              android:id="@+id/textView35"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="6dp"
              android:fontFamily="@font/dmsans_regular"
              android:text="@string/linkedin"
              android:textColor="@color/black"
              android:textSize="14sp"
              app:layout_constraintStart_toEndOf="@+id/imageView13"
              app:layout_constraintTop_toTopOf="@+id/imageView13" />

          <TextView
              android:id="@+id/linkdinlink"
              android:maxLines="1"
              android:ellipsize="end"
              android:clickable="true"
              android:focusable="true"
              android:breakStrategy="simple"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_marginStart="6dp"
              android:layout_marginEnd="16dp"
              android:fontFamily="@font/dmsans_regular"
              android:text="@string/not_specified"
              android:textSize="11sp"
              android:textStyle="italic"
              app:layout_constraintTop_toBottomOf="@+id/textView35"
              app:layout_constraintStart_toEndOf="@+id/imageView13"
              app:layout_constraintEnd_toStartOf="@+id/linkdinedit" />

          <ImageView
              android:id="@+id/linkdinedit"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginEnd="16dp"
              android:alpha="0.5"
              android:importantForAccessibility="no"
              android:src="@drawable/ic_edit"
              app:layout_constraintTop_toTopOf="@+id/linkdinlink"
              app:layout_constraintBottom_toBottomOf="@+id/linkdinlink"
              app:layout_constraintEnd_toEndOf="parent" />

          <ImageView
              android:id="@+id/imageView14"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginStart="16dp"
              android:layout_marginTop="12dp"
              android:alpha="0.8"
              android:importantForAccessibility="no"
              android:src="@drawable/github2"
              app:layout_constraintTop_toBottomOf="@+id/linkdinlink"
              app:layout_constraintStart_toStartOf="parent" />

          <TextView
              android:id="@+id/textView36"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="6dp"
              android:fontFamily="@font/dmsans_regular"
              android:text="@string/github"
              android:textColor="@color/black"
              android:textSize="14sp"
              app:layout_constraintTop_toTopOf="@+id/imageView14"
              app:layout_constraintStart_toEndOf="@+id/imageView14" />

          <TextView
              android:maxLines="1"
              android:ellipsize="end"
              android:breakStrategy="simple"
              android:id="@+id/githublink"
              android:clickable="true"
              android:focusable="true"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_marginStart="6dp"
              android:layout_marginEnd="16dp"
              android:fontFamily="@font/dmsans_regular"
              android:text="@string/not_specified"
              android:textSize="11sp"
              android:textStyle="italic"
              app:layout_constraintTop_toBottomOf="@+id/textView36"
              app:layout_constraintStart_toEndOf="@+id/imageView14"
              app:layout_constraintEnd_toStartOf="@+id/githubedit" />

          <ImageView
              android:id="@+id/githubedit"
              android:layout_width="24dp"
              android:layout_height="24dp"
              android:layout_marginEnd="16dp"
              android:alpha="0.5"
              android:importantForAccessibility="no"
              android:src="@drawable/ic_edit"
              app:layout_constraintTop_toTopOf="@+id/githublink"
              app:layout_constraintBottom_toBottomOf="@+id/githublink"
              app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
      </androidx.cardview.widget.CardView>

      <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="16dp"
          android:layout_marginStart="16dp"
          android:layout_marginEnd="16dp"
          android:layout_marginTop="0dp"
          app:cardCornerRadius="16dp"
          android:elevation="4dp"
          app:cardMaxElevation="6dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">
<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
  android:orientation="horizontal"
    tools:ignore="UseCompoundDrawables">
       <ImageView
           android:layout_width="24dp"
           android:layout_height="24dp"
           android:importantForAccessibility="no" android:src="@drawable/activtystatus"
         android:alpha="1.0"/>
          <TextView
              android:layout_marginStart="6dp"
              android:id="@+id/title_activity_stats"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="@string/activity_status"
              android:textStyle="bold"
              android:fontFamily="@font/dmsans_regular"
              android:textColor="#2E2E2E"
              android:textSize="16sp" />
        </LinearLayout>

          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:gravity="center"
              android:layout_marginTop="12dp">

         
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="100dp"
                android:layout_marginEnd="12dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/activitystatus_background">

              <ImageView
                  android:layout_width="24dp"
                  android:layout_height="24dp"
                  android:importantForAccessibility="no"
                  android:src="@drawable/icons8events" />

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/_0"
                  android:id="@+id/eventscount"
                  android:textStyle="bold"
                  android:textSize="16sp"
                  android:textColor="@color/secondaryColor"
                  android:layout_marginTop="4dp" />

              <TextView
                  android:layout_marginStart="16dp"
                  android:layout_marginEnd="16dp"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/events"
                  android:textSize="14sp"
                  android:textColor="#777777" />
            </LinearLayout>

            
            <LinearLayout

                android:layout_width="wrap_content"
                android:layout_height="100dp"
                android:layout_marginEnd="12dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/activitystatus_background">

              <ImageView
                  android:layout_width="24dp"
                  android:layout_height="24dp"
                  android:importantForAccessibility="no"
                  android:src="@drawable/icons8prize" />

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/_0"
                  android:id="@+id/achivmentcount"
                  android:textStyle="bold"
                  android:textColor="@color/secondaryColor"
                  android:textSize="16sp"
                  android:layout_marginTop="4dp" />

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/achievements"
                  android:textSize="14sp"
                  android:layout_marginStart="8dp"
                  android:layout_marginEnd="8dp"
                  android:textColor="#777777" />
            </LinearLayout>

          
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/activitystatus_background">

              <ImageView
                  android:layout_width="24dp"
                  android:layout_height="24dp"
                  android:importantForAccessibility="no"
                  android:src="@drawable/icons8project" />

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/_0"
                  android:id="@+id/projectcount"
                  android:textStyle="bold"
                  android:textColor="@color/secondaryColor"
                  android:textSize="16sp"
                  android:layout_marginTop="4dp" />

              <TextView
                  android:layout_marginStart="16dp"
                  android:layout_marginEnd="16dp"
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/projects"
                  android:textSize="14sp"
                  android:textColor="#777777" />
            </LinearLayout>
          </LinearLayout>
        </LinearLayout>

      </androidx.cardview.widget.CardView>
      <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_marginBottom="16dp"
          android:layout_marginStart="16dp"
          android:layout_marginEnd="16dp"
          android:layout_marginTop="0dp"
          app:cardCornerRadius="16dp"
          android:elevation="4dp"
          app:cardBackgroundColor="#FFFFFF"
          app:cardMaxElevation="6dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

        
          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="horizontal"
              android:gravity="center_vertical"
              tools:ignore="UseCompoundDrawables">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no" android:src="@drawable/icons8setting150"
            android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/preferences"
                android:fontFamily="@font/dmsans_regular"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#000000" />
          </LinearLayout>

   
          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="20dp"
              android:orientation="horizontal"
              android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_height="wrap_content">

              <TextView
                  android:layout_height="wrap_content"
                  android:text="@string/push_notifications"
                  android:textSize="15sp"
                  android:textStyle="bold"
                  android:textColor="#000000"
                  android:layout_width="wrap_content"/>

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/receive_app_notifications"
                  android:textSize="13sp"
                  android:textColor="#777777" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchPush"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:track="@drawable/track"
                app:trackTint="@null"
                android:thumb="@drawable/thumb"
                android:checked="true" />
          </LinearLayout>

    
          <LinearLayout
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginTop="16dp"
              android:orientation="horizontal"
              android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_height="wrap_content">

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/email_updates"
                  android:textSize="15sp"
                  android:textStyle="bold"
                  android:textColor="#000000" />

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="@string/receive_email_notifications"
                  android:textSize="13sp"
                  android:textColor="#777777" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
               app:track="@drawable/track"
                app:trackTint="@null"
                android:thumb="@drawable/thumb"
                app:useMaterialThemeColors="false"
                android:checked="true" />

          </LinearLayout>
        </LinearLayout>
      </androidx.cardview.widget.CardView>

    </LinearLayout>

  </ScrollView>




</FrameLayout>