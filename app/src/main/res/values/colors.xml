    <color name="secondaryColor">#44A1A0</color>
    <color name="tertiaryColor">#247B7B</color>
    <color name="babypowder">#FFFFFA</color>
    <color name="current">#0D5C63</color>
    <color name="verdigris">#44A1A0</color>
    <color name="Tiffantblue">#78CDD7</color>
    <color name="Teal">#247B7B</color>
