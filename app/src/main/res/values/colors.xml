    <color name="blue_700">#1976D2</color>
    <color name="sky_blue">#03A9F4</color>
    <color name="red_700">#D32F2F</color>
    <color name="linkedin_blue">#0077B5</color>
    <style name="WhiteNavigationIcon">
        <item name="android:tint">@android:color/white</item>

    </style>
    <style name="RoundedImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10%</item> <!-- For circular image -->
    </style>
    <style name="BottomNavActiveIndicator" parent="">
        <item name="android:background">@drawable/nav_item_selected_background</item>
        <item name="android:width">50dp</item>
        <item name="android:height">50dp</item>
        <item name="android:insetTop">5dp</item>
        <item name="android:insetBottom">5dp</item>
    </style>
    <style name="ImageRoundedTop">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>
    <style name="BottomNavTextActive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:fontFamily">@font/dmsans_regular</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item> <!-- or italic, normal -->
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:fontFamily">@font/dmsans_light</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
    </style>





</resources>


